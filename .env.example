# Copy to .env: cp .env.example .env
# Never commit .env to git.

# ─── Grafana admin (required) ─────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change-me-before-starting

# ─── Microsoft OAuth (optional — leave disabled until team SSO is ready) ──────
# GF_OAUTH_ENABLED=false
# GF_OAUTH_CLIENT_ID=
# GF_OAUTH_CLIENT_SECRET=
# GF_OAUTH_AUTH_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/authorize
# GF_OAUTH_TOKEN_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
# GF_OAUTH_API_URL=https://graph.microsoft.com/oidc/userinfo

# ─── Per-env Prometheus scrape tokens ─────────────────────────────────────────
# Each API must accept Authorization: Bearer <token> at /metrics. Match these
# with METRICS_TOKEN on the corresponding API container.
DEV_METRICS_TOKEN=
UAT_METRICS_TOKEN=
PROD_METRICS_TOKEN=
LOCAL_METRICS_TOKEN=

# ─── Loki push token (optional reverse-proxy gate) ────────────────────────────
# If the reverse proxy in front of Loki requires a bearer token, set it here
# and on each API's LOKI_TOKEN env var.
LOKI_TOKEN=
